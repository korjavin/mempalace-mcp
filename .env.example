# MemPalace Bridge — environment variables
# Copy this file to .env and fill in real values before running.
# Never commit .env to version control.

ADMIN_USER=admin
ADMIN_PASSWORD=change_this_to_a_strong_password

# Public URL of your MCP bridge (used for OAuth discovery).
# Set this to the Cloudflare Tunnel URL. If blank, derived from request headers.
PUBLIC_URL=https://mempalace.yourdomain.com
